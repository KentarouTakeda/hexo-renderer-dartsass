{
  "name": "hexo-renderer-dartsass",
  "version": "1.2.0",
  "description": "Sass renderer plugin for Hexo (use dartsass instead of libsass)",
  "main": "dist/",
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KentarouTakeda/hexo-renderer-dartsass.git"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "tsx node_modules/.bin/jasmine",
    "watch": "chokidar 'src/**/*.ts' 'spec/**/*.ts' -c 'npm test'"
  },
  "keywords": [
    "hexo",
    "sass",
    "scss",
    "renderer"
  ],
  "author": "KentarouTakeda",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "sass": "^1.37.5"
  },
  "devDependencies": {
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.6.0",
    "chokidar-cli": "^3.0.0",
    "hexo": "^7.0.0",
    "jasmine": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
